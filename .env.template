# required if you want llm observability, authentication
ALEPHANT_CONTROL_PLANE_API_KEY="sk-alephant-..."
# provider keys, only set the ones you wish to enable
OPENAI_API_KEY="sk-proj-"
ANTHROPIC_API_KEY="sk-..."
GEMINI_API_KEY="fjalksj"
AWS_ACCESS_KEY="asbbj340j"
AWS_SECRET_KEY="kfjd09431"

OTEL_METRIC_EXPORT_INTERVAL=10000

# we use cloud mode
AI_GATEWAY__DEPLOYMENT_TARGET__TYPE=cloud
# database url
POSTGRES_DATABASE_URL=postgres://postgres:@127.0.0.1:5432/alephant_ai
# Compatibility mode: start without PostgreSQL; also set `AI_GATEWAY__ALEPHANT__FEATURES=none` (no auth, no Alephant request-log forwarding).
# Upstream keys come from env (e.g. `OPENAI_API_KEY`), independent of master key / VK.
# AI_GATEWAY__COMPAT_MODE=true
AI_GATEWAY__ALEPHANT__FEATURES=all
AI_GATEWAY__ALEPHANT__BASE_URL="http://alephantai-logs-collector.dev.svc.cluster.local:8585"
# Object storage (S3-compatible API): maps to YAML `s3`, then AI_GATEWAY__S3__*, then flat S3_* overrides (S3_* wins when set and non-empty).
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=request-response-storage
S3_REGION=us-east-1
# Optional: path | virtual-host, same as YAML `url-style`
# S3_URL_STYLE=path
# master key encryption key
MASTER_KEY_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
# Request-log Redis Stream; same URL is used for workspace concurrency and model-catalog EXISTS. If URL is unset with transport=redis, falls back to in-process HTTP.
AI_GATEWAY__REQUEST_LOG__TRANSPORT=http
REDIS_URL="redis://:password@host:6379/15"
# Override Stream key when aligned with logs-collector deployment:
REDIS_STREAM_KEY_REQUEST_RESPONSE=lc:stream:alephant-request-response-logs

# Semantic cache (Qdrant + embeddings, after LLM KV miss)
AI_GATEWAY__SEMANTIC_CACHE__DEFAULT_THRESHOLD_MILLIS=900
AI_GATEWAY__SEMANTIC_CACHE__DEFAULT_TTL_SECONDS=3600
AI_GATEWAY__SEMANTIC_CACHE__QDRANT__URL=http://127.0.0.1:6333
# AI_GATEWAY__SEMANTIC_CACHE__QDRANT__API_KEY=

# Policy content-filter gRPC (matches `policy` in `ai-gateway/config/local-cloud.yaml`; align with policy-service GRPC_ADDR)
# Evaluate timeout, reconnect interval, and body-size limits are constants in `config::policy` (not overridable via env/yaml).
AI_GATEWAY__POLICY__ENABLED=false
AI_GATEWAY__POLICY__GRPC_ENDPOINT=http://127.0.0.1:50051
AI_GATEWAY__POLICY__ON_UNAVAILABLE=deny

# Global per-client-IP rate limit (`global.client-ip-rate-limit`; see `ai-gateway/config/alephant-cloud.yaml` / `local-cloud.yaml`).
# `Config::try_read` loads YAML then `AI_GATEWAY__*`; when both are set, these env vars win.
# `backend=redis` reuses AppRedis for request logs / workspace; falls back to memory with error logs if unset or ping fails.
# `TRUSTED_PROXY_CIDRS`: JSON array string, or indexed keys like `AI_GATEWAY__GLOBAL__CLIENT_IP_RATE_LIMIT__TRUSTED_PROXY_CIDRS__0` (see `client_ip_rate_limit::deserialize_cidr_list`).
# AI_GATEWAY__GLOBAL__CLIENT_IP_RATE_LIMIT__ENABLED=true
# AI_GATEWAY__GLOBAL__CLIENT_IP_RATE_LIMIT__REQUESTS_PER_SECOND=10
# AI_GATEWAY__GLOBAL__CLIENT_IP_RATE_LIMIT__BACKEND=redis
# AI_GATEWAY__GLOBAL__CLIENT_IP_RATE_LIMIT__TRUSTED_PROXY_CIDRS='["10.0.0.0/8"]'
# AI_GATEWAY__GLOBAL__CLIENT_IP_RATE_LIMIT__REDIS_KEY_PREFIX=gw:iprl:

# Gateway-wide in-flight HTTP cap (`global.gateway-in-flight-limit`; not per-IP; independent of `CLIENT_IP_RATE_LIMIT` above).
# AI_GATEWAY__GLOBAL__GATEWAY_IN_FLIGHT_LIMIT__ENABLED=false
# AI_GATEWAY__GLOBAL__GATEWAY_IN_FLIGHT_LIMIT__MAX_CONCURRENT=32
# AI_GATEWAY__GLOBAL__GATEWAY_IN_FLIGHT_LIMIT__BACKEND=redis
# AI_GATEWAY__GLOBAL__GATEWAY_IN_FLIGHT_LIMIT__REDIS_KEY_PREFIX=gw:gifl:

# LLM response KV cache (Cloudflare): active only with `cargo build/run -p ai-gateway --features external`; inject `api-token` via Secret.
# If YAML also exists (e.g. `cloudflare-kv` in `ai-gateway/config/alephant-cloud.yaml`), these `AI_GATEWAY__CLOUDFLARE_KV__*` override YAML.
AI_GATEWAY__CLOUDFLARE_KV__API_BASE=https://api.cloudflare.com/client/v4
AI_GATEWAY__CLOUDFLARE_KV__ACCOUNT_ID=
AI_GATEWAY__CLOUDFLARE_KV__NAMESPACE_ID=
AI_GATEWAY__CLOUDFLARE_KV__API_TOKEN=

# LLM response KV cache (TiKV Raw KV): optional only with `cargo build/run -p ai-gateway --features internal`; if unset, uses in-memory stub (no hits).
# Provide PD endpoints via YAML list or repeated env keys (depends on config crate merge); examples are placeholders—do not commit real addresses.
# PD list: either `__0`/`__1` indices or JSON array string (see `tikv_kv::deserialize_pd_endpoints`)
AI_GATEWAY__TIKV_KV__PD_ENDPOINTS='["127.0.0.1:2379"]'
# TLS (optional): PEM path for CA verifying PD/TiKV; equivalent to YAML `tikv-kv.ca-cert-path`.
# `Config::try_read` loads YAML then `AI_GATEWAY__*`; when both are set for this section, this variable wins.
AI_GATEWAY__TIKV_KV__CA_CERT_PATH=
